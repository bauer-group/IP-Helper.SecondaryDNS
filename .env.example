# =============================================================================
# Secondary DNS Server - Konfiguration
# =============================================================================
#
# Kopieren Sie diese Datei nach .env und passen Sie die Werte an:
#   cp .env.example .env
#
# Mehrere Primary-Server koennen parallel betrieben werden, jeder mit
# IPv4 und/oder IPv6. Pflicht: PRIMARY_1_HOSTNAME plus mindestens eine IP.
#
# Weitere Primaries spaeter zur Laufzeit hinzufuegen:
#   dns-admin primary add ns3.example.com 192.0.2.30 2001:db8::30
#
# =============================================================================

# -----------------------------------------------------------------------------
# PRIMARY DNS SERVER (mind. ein Primary erforderlich)
# -----------------------------------------------------------------------------

# Primary 1 (Pflicht)
PRIMARY_1_HOSTNAME="ns1.example.com"
PRIMARY_1_IPV4="203.0.113.10"
PRIMARY_1_IPV6="2001:db8::10"

# Primary 2 (Optional - einfach Block einkommentieren)
# PRIMARY_2_HOSTNAME="ns2.example.com"
# PRIMARY_2_IPV4="203.0.113.11"
# PRIMARY_2_IPV6="2001:db8::11"

# Primary 3 (Optional)
# PRIMARY_3_HOSTNAME="ns3.example.com"
# PRIMARY_3_IPV4="203.0.113.12"
# PRIMARY_3_IPV6="2001:db8::12"

# -----------------------------------------------------------------------------
# PFLICHTANGABEN
# -----------------------------------------------------------------------------

# E-Mail fuer System-Benachrichtigungen (Updates, Fehler)
ADMIN_EMAIL="admin@example.com"

# -----------------------------------------------------------------------------
# OPTIONAL - SSH KONFIGURATION
# -----------------------------------------------------------------------------

# SSH Public Key fuer passwortlosen Login (leer lassen wenn nicht benoetigt)
SSH_PUBKEY=""

# Passwort-Login erlauben (true/false)
# Default: true
SSH_PASSWORD_AUTH="true"

# -----------------------------------------------------------------------------
# OPTIONAL - SYSTEM KONFIGURATION
# -----------------------------------------------------------------------------

# Hostname fuer diesen Server (ohne Domain)
# Default: ns2
SECONDARY_HOSTNAME="ns2"

# FQDN fuer diesen Server
# Default: ns2.local
SECONDARY_FQDN="ns2.example.com"

# Zeitzone
# Default: Etc/UTC
TIMEZONE="Etc/UTC"

# -----------------------------------------------------------------------------
# OPTIONAL - AUTO-UPDATE KONFIGURATION
# -----------------------------------------------------------------------------

# Automatischer Reboot bei Kernel-Updates (true/false)
# Default: true
AUTO_REBOOT="true"

# Uhrzeit fuer automatische Reboots (HH:MM)
# Default: 03:00
REBOOT_TIME="03:00"

# -----------------------------------------------------------------------------
# OPTIONAL - TSIG-KEY FUER SICHERE ZONE-TRANSFERS
# -----------------------------------------------------------------------------

# TSIG-Key fuer authentifizierte Zone-Transfers (optional, erhoeht Sicherheit)
# Format: name:algorithm:secret
# Beispiel: "transfer-key:hmac-sha256:BASE64ENCODEDKEY=="
# Der gleiche Key muss auf dem Primary DNS konfiguriert sein!
# Leer lassen wenn nicht benoetigt (IP-Whitelist reicht fuer die meisten Faelle)
TSIG_KEY=""
